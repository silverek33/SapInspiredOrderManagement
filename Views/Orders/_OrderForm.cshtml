@model CreateOrderViewModel

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<div class="form-grid">
    <div>
        <label asp-for="CustomerId" class="form-label"></label>
        <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select">
            <option value="">Select customer</option>
        </select>
        <span asp-validation-for="CustomerId" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Priority" class="form-label"></label>
        <select asp-for="Priority" asp-items="Html.GetEnumSelectList<OrderPriority>()" class="form-select"></select>
        <span asp-validation-for="Priority" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="OrderDate" class="form-label"></label>
        <input asp-for="OrderDate" class="form-control" />
        <span asp-validation-for="OrderDate" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="RequestedDeliveryDate" class="form-label"></label>
        <input asp-for="RequestedDeliveryDate" class="form-control" />
        <span asp-validation-for="RequestedDeliveryDate" class="text-danger"></span>
    </div>
    <div class="form-span">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>
</div>

<div class="section-title order-lines-title">
    <h2>Order items</h2>
    <span>Prices are copied from active product master data.</span>
</div>

<div class="order-lines">
    @for (var i = 0; i < Model.Items.Count; i++)
    {
        <div class="order-item-row">
            <div>
                <label asp-for="Items[i].ProductId" class="form-label">Product</label>
                <select asp-for="Items[i].ProductId" asp-items="Model.Products" class="form-select">
                    <option value="">Select product</option>
                </select>
                <span asp-validation-for="Items[i].ProductId" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Items[i].Quantity" class="form-label"></label>
                <input asp-for="Items[i].Quantity" class="form-control" />
                <span asp-validation-for="Items[i].Quantity" class="text-danger"></span>
            </div>
        </div>
    }
</div>
