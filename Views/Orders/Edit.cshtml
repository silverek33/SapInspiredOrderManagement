@model CreateOrderViewModel

@{
    ViewData["Title"] = "Edit order";
}

<section class="page-heading">
    <p class="eyebrow">Draft control</p>
    <h1>Edit @ViewBag.OrderNumber</h1>
    <p>Draft orders can be corrected before submission.</p>
</section>

<form asp-action="Edit" asp-route-id="@ViewBag.OrderId" method="post" class="business-form">
    <partial name="_OrderForm" model="Model" />
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Draft</button>
        <a asp-action="Details" asp-route-id="@ViewBag.OrderId" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
